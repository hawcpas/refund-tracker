{
  "functions": {
    "source": "functions"
  },
  "flutter": {
    "platforms": {
      "android": {
        "default": {
          "projectId": "axume-portal-6bfd3",
          "appId": "1:397125649830:android:08fa429ec5e955bd60bb67",
          "fileOutput": "android/app/google-services.json"
        }
      }
    },
    "dart": {
      "lib/firebase_options.dart": {
        "projectId": "axume-portal-6bfd3",
        "configurations": {
          "android": "1:397125649830:android:08fa429ec5e955bd60bb67",
          "ios": "1:397125649830:ios:3aa5a515f9eaa0e460bb67",
          "macos": "1:397125649830:ios:3aa5a515f9eaa0e460bb67",
          "web": "1:397125649830:web:ae8c2a889c5d73e460bb67",
          "windows": "1:397125649830:web:bf7e494428d425c960bb67"
        }
      }
    }
  },
  "hosting": {
    "public": "build/web",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "headers": [
      {
        "source": "/email/**",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
        ]
      },
      {
        "source": "**/*.png",
        "headers": [
          { "key": "Content-Type", "value": "image/png" },
          { "key": "Cache-Control", "value": "public, max-age=31536000" }
        ]
      },
      {
        "source": "**/*.jpg",
        "headers": [
          { "key": "Content-Type", "value": "image/jpeg" },
          { "key": "Cache-Control", "value": "public, max-age=31536000" }
        ]
      },
      {
        "source": "**/*.jpeg",
        "headers": [
          { "key": "Content-Type", "value": "image/jpeg" },
          { "key": "Cache-Control", "value": "public, max-age=31536000" }
        ]
      },
      {
        "source": "**/*.svg",
        "headers": [
          { "key": "Content-Type", "value": "image/svg+xml" },
          { "key": "Cache-Control", "value": "public, max-age=31536000" }
        ]
      }
    ],
    "rewrites": [
      {
        "source": "/email/**",
        "destination": "/email/**"
      },
      {
        "source": "**",
        "has": [
          {
            "type": "header",
            "name": "User-Agent",
            "value": ".*(Teams|Outlook|Slack|Twitter|LinkedIn|bot|crawler).*"
          }
        ],
        "destination": "/og.html"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}